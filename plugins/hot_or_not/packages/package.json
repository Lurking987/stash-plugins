{
  "name": "stash-hot-or-not",
  "version": "3.0.0",
  "description": "Refactored HotOrNot plugin for Stash",
  "main": "main.js",
  "scripts": {
    "build": "esbuild main.js --bundle --format=iife --platform=browser --outfile=hot_or_not.js",
    "watch": "esbuild main.js --bundle --format=iife --outfile=hot_or_not.js --watch",
    "minify": "esbuild main.js --bundle --minify --format=iife --platform=browser --outfile=hot_or_not.min.js"
  },
  "devDependencies": {
    "esbuild": "^0.20.0"
  }
}
